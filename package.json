{
  "name": "@jchoi2x/minijinja",
  "version": "0.0.3",
  "type": "module",
  "main": "./pkg/web/minijinja.js",
  "types": "./pkg/web/minijinja.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "pkg/web/**",
    "pkg/node/**",
    "pkg/workerd/**"
  ],
  "exports": {
    ".": {
      "workerd": "./pkg/workerd/minijinja.js",
      "browser": "./pkg/web/minijinja.js",
      "node": "./pkg/node/minijinja.js",
      "default": "./pkg/web/minijinja.js"
    },
    "./minijinja_bg.wasm": {
      "workerd": "./pkg/workerd/minijinja_bg.wasm",
      "browser": "./pkg/web/minijinja_bg.wasm",
      "node": "./pkg/node/minijinja_bg.wasm",
      "default": "./pkg/web/minijinja_bg.wasm"
    }
  },
  "description": "WASM binding for minijinja",
  "scripts": {
    "clean": "rm -rf pkg",
    "build:web": "wasm-pack build --target web --scope jchoi2x --out-dir pkg/web --out-name minijinja",
    "build:node": "wasm-pack build --target nodejs --scope jchoi2x --out-dir pkg/node --out-name minijinja",
    "build:workerd": "wasm-pack build --target bundler --scope jchoi2x --out-dir pkg/workerd --out-name minijinja",
    "build": "pnpm run clean && pnpm run build:web && pnpm run build:node && pnpm run build:workerd",
    "publish:gh": "pnpm run build && npm publish",
    "prepublish": "pnpm build"
  },
  "author": "OpenRouter",
  "contributors": [
    "@openrouter/hackers"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenRouterTeam/minijinja.git"
  },
  "license": "MIT",
  "devDependencies": {
    "wasm-pack": "0.13.0",
    "typescript": "5.4.5",
    "prettier": "3.3.2"
  }
}
